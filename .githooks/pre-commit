#!/usr/bin/env zsh
# .githooks/pre-commit
# Scan staged changes for secrets before allowing commit

set -euo pipefail

if ! command -v gitleaks &>/dev/null; then
  echo "[❌] gitleaks not found. Install via: brew install gitleaks"
  exit 1
fi

gitleaks protect --staged --verbose

# Block commits containing PII patterns (one grep -E pattern per line)
pii_file="$(git rev-parse --show-toplevel)/.githooks/pii-patterns"

if [[ -f "${pii_file}" ]]; then
  pii_patterns=""
  while IFS= read -r line; do
    [[ -z "${line}" || "${line}" == \#* ]] && continue
    pii_patterns="${pii_patterns:+${pii_patterns}|}${line}"
  done < "${pii_file}"

  if [[ -n "${pii_patterns}" ]] \
    && git diff --cached --diff-filter=d -U0 | grep '^+' | grep -v '^+++' | grep -qiE "${pii_patterns}"; then
    echo "[❌] Staged changes contain a PII pattern."
    echo "     Redact before committing."
    git diff --cached --diff-filter=d -U0 \
      | grep '^+' | grep -v '^+++' \
      | grep -inE "${pii_patterns}" \
      | head -5
    exit 1
  fi
fi

# When bittersweet is staged, keep .completions/_bittersweet locked to
# BITTERSWEET_SUBCOMMANDS and hard-fail the commit on parity drift.
#
# Two-step enforcement:
#  1. Regenerate the completion from the SOT array. Catches the dev who
#     edited BITTERSWEET_SUBCOMMANDS without rerunning `bittersweet
#     completions`. The regenerated file is auto-staged so the commit is
#     internally consistent.
#  2. Run `./test completions` for the parity check. The regen alone CANNOT
#     detect a phantom dispatch arm without a matching SOT entry — the
#     generator only reads the array, so a forgotten array entry produces
#     a "complete" (with itself) but stale-vs-dispatch completion file.
#     The parity assertion compares case arms against array keys directly.
#
# --no-verify still bypasses both. CI is the only unbypassable layer.
completion_test_output=""
if git diff --cached --name-only --diff-filter=d | grep -qx 'bittersweet'; then
  if [[ -x ./bittersweet ]]; then
    ./bittersweet completions >/dev/null
    if ! git diff --quiet -- .completions/_bittersweet; then
      git add .completions/_bittersweet
      echo "[ℹ️ ] Regenerated and staged .completions/_bittersweet"
    fi
  fi
  if ! completion_test_output=$(./test completions 2>&1); then
    echo "[❌] bittersweet subcommand drift detected — commit blocked:"
    echo "${completion_test_output}"
    exit 1
  fi
fi
