# .npmrc
# https://docs.npmjs.com/cli/v11/using-npm/config

# Don't install packages published less than 3 days ago
# npm equivalent of uv's exclude-newer. Value is in days (integer)
# Override: --min-release-age=0
min-release-age=3

# Block preinstall/postinstall/install lifecycle scripts
# Node equivalent of setup.py attacks
# Override: --ignore-scripts=false or per-project .npmrc
ignore-scripts=true

# Pin exact versions when saving deps (no ^ or ~ prefix)
# Prevents semver range drift pulling in a compromised 
#  minor/patch release automatically
save-exact=true

# Block git dependencies, "none" blocks all git deps
# override with --allow-git=root for direct deps
# Becomes the default in npm 12
allow-git=none

# Require TLS certificate validation. Default is true but explicit here to
# prevent a project-level .npmrc from downgrading to strict-ssl=false
# (WTFpkg npmrc-manipulation attack class)
strict-ssl=true

# Prefer locally cached packages over remote fetches. Reduces exposure to
# registry compromise and npx typosquatting — npm falls back to remote
# only when the package is not in the local cache
prefer-offline=true

# Set minimum vulnerability level for npm audit to return non-zero.
# "low" adds noise (informational prototype pollution, ReDoS in unused
# transitive deps). Moderate catches everything actionable.
# Periodic npm-audit-check runs both audit and audit signatures.
audit-level=moderate
