#!/bin/zsh
# dotfiles/tests/santa-faa
#
# Test Santa FAA (File Access Authorization) rules. Verifies that watched
# paths are protected and that allowlisted processes can still access them.
#
# Usage (via dispatcher):
#   ./test santa-faa                  — run all rule tests
#   ./test santa-faa ssh-config       — SSH config protection only
#   ./test santa-faa git-signing      — git signing config protection only
#   ./test santa-faa shell-startup    — shell startup config protection only
#   ./test santa-faa shell-functions  — shell functions protection only
#   ./test santa-faa claude-config    — Claude Code config protection only
#
# ShellCheck: lint with `shellcheck --shell=bash tests/santa-faa`.
# This file is sourced, not executed — chmod 644.
#
# shellcheck source=tests/lib

# ── ssh-config ─────────────────────────────────
# Rules: SSHConfigSymlinks + SSHConfigResolved
# SSHConfigResolved is AuditOnly (Xcode git signing issue — can't allowlist git).
# ES resolves symlinks for OPEN, so reads through symlinks hit the Resolved rule.
# Allowed: com.apple.ssh, com.apple.scp, com.apple.sftp, com.sublimetext.4,
#          com.fournova.Tower3, com.apple.ln (symlink rules only)
function _faa_ssh_config {
  _section "ssh-config (SSHConfigSymlinks + SSHConfigResolved) [AuditOnly]"

  local paths=(
    "${HOME}/.ssh/config"
    "${HOME}/.ssh/.extra_ssh"
    "${HOME}/Documents/Projects/dotfiles/.ssh/config"
    "${HOME}/Documents/Projects/dotfiles/.ssh/.extra_ssh"
  )

  local p
  for p in "${paths[@]}"; do
    if [[ ! -e "${p}" ]]; then
      _skip "path missing: ${p}"
      continue
    fi
    _skip "AuditOnly: ${p}"
  done

  # ssh -G dumps resolved config to stdout without connecting
  _expect_allowed "ssh allowed: reads config via ssh -G" /usr/bin/ssh -G localhost
}

# ── git-signing ───────────────────────────────
# Rules: GitSigningConfig + GitSigningConfigResolved
# Currently AuditOnly — git spawns many helper binaries that all read config,
# and neither PlatformBinary nor TeamID matching works for Xcode developer tools.
# Blocked tests are skipped; allowed test confirms git can still read config.
# Allowed: com.apple.git, com.apple.git-remote-http, com.sublimetext.4
function _faa_git_signing {
  _section "git-signing (GitSigningConfig + GitSigningConfigResolved) [AuditOnly]"

  local paths=(
    "${HOME}/.config/git/config"
    "${HOME}/.config/git/allowed_signers"
    "${HOME}/Documents/Projects/dotfiles/.config/git/config"
    "${HOME}/Documents/Projects/dotfiles/.config/git/allowed_signers"
  )

  local p
  for p in "${paths[@]}"; do
    if [[ ! -e "${p}" ]]; then
      _skip "path missing: ${p}"
      continue
    fi
    _skip "AuditOnly: ${p}"
  done

  # git config --list reads ~/.config/git/config
  _expect_allowed "git allowed: reads config via git config --list" /usr/bin/git config --list
}

# ── shell-startup ─────────────────────────────
# Rules: ShellStartupConfig + ShellStartupConfigResolved
# ShellStartupConfigResolved is AuditOnly (Xcode git signing issue).
# ES resolves symlinks for OPEN, so reads through symlinks hit the Resolved rule.
# Allowed: com.apple.zsh, com.sublimetext.4, com.apple.ln (symlink rules only)
function _faa_shell_startup {
  _section "shell-startup (ShellStartupConfig + ShellStartupConfigResolved) [AuditOnly]"

  local paths=(
    "${HOME}/.zshrc"
    "${HOME}/.aliases"
    "${HOME}/Documents/Projects/dotfiles/.zshrc"
    "${HOME}/Documents/Projects/dotfiles/.aliases"
  )

  local p
  for p in "${paths[@]}"; do
    if [[ ! -e "${p}" ]]; then
      _skip "path missing: ${p}"
      continue
    fi
    _skip "AuditOnly: ${p}"
  done

  # zsh -c sources .zshrc — confirms zsh is allowlisted
  _expect_allowed "zsh allowed: sources .zshrc via zsh -c" /bin/zsh -c "source ${HOME}/.zshrc"
}

# ── shell-functions ───────────────────────────
# Rules: ShellFunctions + ShellFunctionsResolved
# ShellFunctionsResolved is AuditOnly (Xcode git signing issue).
# ES resolves symlinks for OPEN, so reads through symlinks hit the Resolved rule.
# Allowed: com.apple.zsh, com.sublimetext.4, com.apple.ln (symlink rules only)
function _faa_shell_functions {
  _section "shell-functions (ShellFunctions + ShellFunctionsResolved) [AuditOnly]"

  local paths=(
    "${HOME}/.functions/jump"
    "${HOME}/.functions/layup"
    "${HOME}/Documents/Projects/dotfiles/.functions/jump"
    "${HOME}/Documents/Projects/dotfiles/.functions/layup"
  )

  local p
  for p in "${paths[@]}"; do
    if [[ ! -e "${p}" ]]; then
      _skip "path missing: ${p}"
      continue
    fi
    _skip "AuditOnly: ${p}"
  done

  # zsh autoload reads function files from FPATH
  _expect_allowed "zsh allowed: autoloads function via zsh -c" /bin/zsh -c \
    "fpath=(${HOME}/.functions \$fpath); autoload -Uz jump; whence -v jump"
}

# ── claude-config ─────────────────────────────
# Rules: ClaudeCodeConfig + ClaudeCodeConfigResolved
# Watched: ~/.claude/settings.json, dotfiles/claude/settings.json
# Allowed: com.anthropic.claude-code, com.sublimetext.4
function _faa_claude_config {
  _section "claude-config (ClaudeCodeConfig + ClaudeCodeConfigResolved)"

  local paths=(
    "${HOME}/.claude/settings.json"
    "${HOME}/Documents/Projects/dotfiles/claude/settings.json"
  )

  local p
  for p in "${paths[@]}"; do
    if [[ ! -e "${p}" ]]; then
      _skip "path missing: ${p}"
      continue
    fi
    _expect_blocked "cat blocked: ${p}" /bin/cat "${p}"
  done

  # claude -p reads settings.json on startup to load hooks/permissions
  local claude_bin
  claude_bin="$(command -v claude 2>/dev/null || true)"
  if [[ -z "${claude_bin}" ]]; then
    _skip "claude binary not found"
  else
    _expect_allowed "claude allowed: reads settings via claude -p" \
      "${claude_bin}" -p "reply ok"
  fi
}

function run_santa_faa {
  local filter="${1:-}"

  # Preflight: Watch Items must be enabled. Skip the suite if not — the suite
  # is sourced into a shared shell, so `exit 1` would kill the whole dispatcher.
  if ! command -v santactl >/dev/null 2>&1; then
    _skip "santactl not installed — Santa FAA suite skipped"
    return 0
  fi

  local watch_section
  watch_section="$(santactl status 2>&1 | grep -A1 "Watch Items")"
  if ! grep -q "Enabled.*Yes" <<< "${watch_section}"; then
    _skip "Santa Watch Items not enabled — run \`santactl status | grep -A5 'Watch Items'\`"
    return 0
  fi

  local version
  version="$(santactl status 2>&1 | grep 'Policy Version' | awk -F'|' '{print $2}' | xargs)"
  echo "Santa FAA tests (policy ${version})"

  case "${filter}" in
    ""              ) _faa_ssh_config; _faa_git_signing; _faa_shell_startup; _faa_shell_functions; _faa_claude_config ;;
    ssh-config      ) _faa_ssh_config ;;
    git-signing     ) _faa_git_signing ;;
    shell-startup   ) _faa_shell_startup ;;
    shell-functions ) _faa_shell_functions ;;
    claude-config   ) _faa_claude_config ;;
    *               ) _fail "Unknown santa-faa rule: ${filter}"; return 1 ;;
  esac
}
