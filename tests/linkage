#!/bin/zsh
# dotfiles/tests/linkage
#
# Detect repo files not managed by any bittersweet subcommand.
# Prevents "forgot to wire up" bugs — e.g. Ghostty config sat in the
# repo without a symlink in install_dotfiles until it was caught manually.
#
# Maintains a manifest of every repo file/dir and its owner. New files
# that aren't in the manifest fail the test, forcing a conscious decision
# about where the file should be installed.
#
# ShellCheck: lint with `shellcheck --shell=bash tests/linkage`.
# This file is sourced, not executed — chmod 644.
#
# shellcheck source=tests/lib

function run_linkage {
  _section "Dotfile Coverage"

  # SC2154: fail_count is declared in tests/lib, sourced by the dispatcher.
  # shellcheck disable=SC2154
  local before_fails=${fail_count}

  # Every top-level item → owning bittersweet subcommand.
  # "repo" = docs, metadata, test infra — intentionally not installed.
  local -A top_level=(
    # Repo metadata
    [CLAUDE.md]=repo
    [LICENSE]=repo
    [README.md]=repo
    [SECURITY.md]=repo
    [TODOs.md]=repo
    [.gitignore]=repo
    [.gitleaksignore]=repo

    # Script + test infra
    [bittersweet]=install_scripts
    [test]=repo
    [tests]=repo

    # install_dotfiles — config files symlinked into HOME
    [.zshrc]=install_dotfiles
    [.aliases]=install_dotfiles
    [.functions]=install_dotfiles
    [.completions]=install_dotfiles
    [.ssh]=install_dotfiles
    [.config]=install_dotfiles
    [config]=install_dotfiles              # Ghostty
    [IDETemplateMacros.plist]=install_dotfiles  # Xcode
    [claude]=install_dotfiles              # Dynamic (skills, rules, settings)
    [.githooks]=install_dotfiles           # core.hooksPath

    # Other bittersweet subcommands
    [bin]=install_scripts
    [profiles]=santa
    [LaunchAgents]=install_launchagents
    [LaunchDaemons]=install_launchagents
    ["Sublime Text"]=sublimetext
    [.extra]=extra
    [.github]=repo
    [internals]=repo
    [templates]=repo
    [poc]=repo
  )

  # .config/ subdirs must each be wired in install_dotfiles
  local -A config_subdirs=(
    [git]=install_dotfiles
    [uv]=install_dotfiles
    [npm]=install_dotfiles
    [1Password]=install_dotfiles
    [dcg]=install_dotfiles
  )

  # bin/ scripts → owning subcommand
  local -A bin_scripts=(
    # install_scripts → /usr/local/bin/
    [dns]=install_scripts
    [jump-user]=install_scripts
    [jump-system]=install_scripts
    [danger]=install_scripts
    [mdview]=install_scripts
    [npm-audit-check]=install_scripts
    [claude-session-audit]=install_scripts
    # install_dotfiles → ~/.local/bin/ (op wrappers)
    [vt]=install_dotfiles
    [urlscan]=install_dotfiles
    # Manually-run scripts
    [survey]=repo
  )

  # claude/ files → owning subcommand (rules/ and skills/ are dynamic)
  local -A claude_items=(
    [settings.json]=install_dotfiles
    [global-claude.md]=install_dotfiles
    [statusline-command]=install_dotfiles
    [lint-hook]=install_dotfiles
    [rules]=install_dotfiles                 # Dynamic (individual rules)
    [skills]=install_dotfiles                # Dynamic (individual skills)
  )

  # LaunchAgent plists must each be in install_launchagents
  local -A launchagent_plists=(
    [com.0xmachos.jump-user.plist]=install_launchagents
    [com.0xmachos.vault-guard.plist]=install_launchagents
    [com.0xmachos.imageio-oop.plist]=install_launchagents
  )

  # LaunchDaemon plists
  local -A launchdaemon_plists=(
    [com.0xmachos.jump-system.plist]=install_launchagents
  )

  local name

  # 1. Top-level items
  local item
  for item in ./* ./.[!.]*; do
    [[ -e "${item}" ]] || continue
    name="${item##*/}"
    [[ "${name}" == ".git" || "${name}" == ".DS_Store" || "${name}" == ".claude" ]] && continue
    if [[ -z "${top_level[${name}]+_}" ]]; then
      _fail "Untracked top-level: ${name} (add to install_dotfiles or top_level map)"
    fi
  done

  # 2. .config/ subdirectories
  local subdir
  for subdir in .config/*/; do
    [[ -d "${subdir}" ]] || continue
    name="${subdir%/}"
    name="${name##*/}"
    if [[ -z "${config_subdirs[${name}]+_}" ]]; then
      _fail "Untracked .config/ subdir: ${name} (add symlink to install_dotfiles and config_subdirs map)"
    fi
  done

  # 3. bin/ scripts
  local script
  for script in bin/*; do
    [[ -f "${script}" ]] || continue
    name="${script##*/}"
    if [[ -z "${bin_scripts[${name}]+_}" ]]; then
      _fail "Untracked bin/ script: ${name} (add to install_scripts or bin_scripts map)"
    fi
  done

  # 4. LaunchAgent plists
  local plist
  for plist in LaunchAgents/*.plist; do
    [[ -f "${plist}" ]] || continue
    name="${plist##*/}"
    if [[ -z "${launchagent_plists[${name}]+_}" ]]; then
      _fail "Untracked LaunchAgent: ${name} (add to install_launchagents and launchagent_plists map)"
    fi
  done

  # 5. LaunchDaemon plists
  for plist in LaunchDaemons/*.plist; do
    [[ -f "${plist}" ]] || continue
    name="${plist##*/}"
    if [[ -z "${launchdaemon_plists[${name}]+_}" ]]; then
      _fail "Untracked LaunchDaemon: ${name} (add to install_launchagents and launchdaemon_plists map)"
    fi
  done

  # 6. claude/ items (files and subdirs, skip .DS_Store)
  local claude_item
  for claude_item in claude/*; do
    [[ -e "${claude_item}" ]] || continue
    name="${claude_item##*/}"
    [[ "${name}" == ".DS_Store" ]] && continue
    if [[ -z "${claude_items[${name}]+_}" ]]; then
      _fail "Untracked claude/ item: ${name} (add to claude_files in install_dotfiles and claude_items map)"
    fi
  done

  if (( fail_count == before_fails )); then
    _pass "All repo files accounted for"
  fi
}
