#!/bin/zsh
# dotfiles/tests/santa-profile
#
# Validate the Santa BlockedPathRegex mobileconfig profile:
#   1. Profile structure (PlistBuddy key/value invariants)
#   2. Regex path coverage (must-match / must-not-match sets)
#   3. Required path invariants (defend against deleting a whole regex branch)
#
# This suite is orthogonal to tests/santa-faa — that one tests runtime
# FAA enforcement; this one tests the mobileconfig before it's deployed.
#
# ShellCheck: lint with `shellcheck --shell=bash tests/santa-profile`.
# This file is sourced, not executed — chmod 644.
#
# shellcheck source=tests/lib

function run_santa_profile {
  _section "Santa profile"

  local profile="profiles/com.0xmachos.santa.mobileconfig"
  local pb="/usr/libexec/PlistBuddy"

  if ! [[ -x "${pb}" ]]; then
    _skip "PlistBuddy not found, skipping Santa profile tests"
    return 0
  fi

  if ! [[ -f "${profile}" ]]; then
    _fail "Santa profile not found: ${profile}"
    return 0
  fi

  # SC2154: fail_count is declared in tests/lib, sourced by the dispatcher.
  # shellcheck disable=SC2154
  local before_fails=${fail_count}

  local keypath expected actual

  while IFS='|' read -r keypath expected; do
    actual=""
    actual="$("${pb}" -c "Print ${keypath}" "${profile}" 2>/dev/null)" || true
    if [[ "${actual}" != "${expected}" ]]; then
      _fail "${keypath}: expected '${expected}', got '${actual}'"
    fi
  done <<'CHECKS'
:PayloadRemovalDisallowed|true
:PayloadScope|System
:TargetDeviceType|5
:PayloadType|Configuration
:PayloadContent:0:PayloadType|com.northpolesec.santa
:PayloadEnabled|true
:PayloadContent:0:PayloadEnabled|true
CHECKS

  # Top-level and nested PayloadUUIDs must differ
  local top_uuid nested_uuid
  top_uuid=""
  top_uuid="$("${pb}" -c "Print :PayloadUUID" "${profile}" 2>/dev/null)" || true
  nested_uuid=""
  nested_uuid="$("${pb}" -c "Print :PayloadContent:0:PayloadUUID" "${profile}" 2>/dev/null)" || true

  if [[ -z "${top_uuid}" ]] || [[ -z "${nested_uuid}" ]]; then
    _fail "PayloadUUID: could not extract one or both UUIDs"
  elif [[ "${top_uuid}" == "${nested_uuid}" ]]; then
    _fail "PayloadUUID: top-level and nested UUIDs must differ"
  fi

  # BlockedPathRegex must be non-empty
  local regex
  regex=""
  regex="$("${pb}" -c "Print :PayloadContent:0:BlockedPathRegex" "${profile}" 2>/dev/null)" || true

  if [[ -z "${regex}" ]]; then
    _fail "BlockedPathRegex: empty or missing"
    return 0
  fi

  local -a must_match=(
    "/Volumes/Vault/malware.bin"
    "/Volumes/Vault/subdir/file"
    "/Volumes/Vault/.hidden"
    "/Volumes/Vault/"
    "/Volumes/dmg-cage/sample.exe"
    "/Volumes/dmg-cage/deep/nested/path"
    "/Users/testuser/Downloads/suspicious.app"
    "/Users/testuser/Downloads/.test-exec"
    "/Users/testuser/Downloads/path with spaces/file"
  )

  local -a must_not_match=(
    "/Volumes/Vault"
    "/Volumes/VaultExtra/file"
    "/Volumes/dmg-cage"
    "/Volumes/dmg-cages/file"
    "/tmp/anything"
    "/usr/bin/true"
    "/Users/testuser/Desktop/file"
    "/Users/testuser/x/Downloads/file"
  )

  local path
  for path in "${must_match[@]}"; do
    if ! /usr/bin/grep -Eq "${regex}" <<< "${path}"; then
      _fail "BlockedPathRegex must match: ${path}"
    fi
  done

  for path in "${must_not_match[@]}"; do
    if /usr/bin/grep -Eq "${regex}" <<< "${path}"; then
      _fail "BlockedPathRegex must NOT match: ${path}"
    fi
  done

  local -a required_substrings=(
    "/Volumes/Vault/"
    "/Volumes/dmg-cage/"
    "/Users/[^/]+/Downloads/"
  )

  local stripped
  stripped="${regex//\\/}"

  local substr
  for substr in "${required_substrings[@]}"; do
    if [[ "${stripped}" != *"${substr}"* ]]; then
      _fail "BlockedPathRegex missing required path: ${substr}"
    fi
  done

  if (( fail_count == before_fails )); then
    _pass "Santa profile ($(/usr/bin/basename "${profile}"))"
  fi
}
