#!/usr/bin/env zsh
# ~/.aliases


#   -----------------------------
#   1. REMAP DEFAULT COMMANDS
#   -----------------------------

# Go up 1-4 directory levels
alias ..='cd ..' 
alias ...='cd ../..' 
alias ....='cd ../../..'
alias .....='cd ../../../..'

# Clear terminal window
alias c='clear'

# Preferred ls behaviour
alias ll='ls -aFGhlt'
# -a show files and dirs starting with .
# -F write `/' after directories, '*' after executables and '@' after symlinks
# -G enable colorised output
# -h show sizes in human readable form
# -l display in long format
# -t sort by descending time modified

# Better ls, don't always want long format
alias ls='ls -FG'
# -F write `/' after directories, '*' after executables and '@' after symlinks
# -G enable colorised output

# Preferred grep behaviour
alias grep='grep --color=auto '
# Highlight match with colour

# ripgrep: search everything (hidden files + VCS-ignored files), skip .git/
alias rga='rg --hidden --no-ignore --glob "!.git/"'

# fd: search everything (hidden files + VCS-ignored files), skip .git/
alias fda='fd --hidden --no-ignore --exclude .git'

# Enable all clang warnings
alias cc='cc -Wall'

# Use macos-trash instead of rm (moves to Finder Bin, strips rm flags)
alias rm='/opt/homebrew/opt/macos-trash/bin/trash'

# unlink(1) removes a single file — same effect as rm, bypasses the rm alias
alias unlink='/opt/homebrew/opt/macos-trash/bin/trash'

# shred/gshred: multi-pass overwrite is meaningless on APFS (CoW) + SSD (TRIM)
alias shred='/opt/homebrew/opt/macos-trash/bin/trash'
alias gshred='/opt/homebrew/opt/macos-trash/bin/trash'


#   -----------------------------
#   2. MAP CUSTOM COMMANDS
#   -----------------------------

## Navigation
# cd into HOME/Downloads directory
alias dl='cd ~/Downloads'
# cd into HOME/Desktop directory
alias dk='cd ~/Desktop'
# cd into HOME/Documents/Projects directory
alias pj='cd ~/Documents/Projects'
# cd into HOME/Documents/Projects/dotfiles directory
alias dot='cd ~/Documents/Projects/dotfiles'
# cd in /Applications
alias ap='cd /Applications/'
# cd into HOME/Documents/Projects directory
alias xdd='cd ~/Library/Developer/Xcode/DerivedData'
# EndpointSecurity SDK headers path (AUTO_CD will cd into it)
alias esh='"$(sdkpath)/usr/include/EndpointSecurity"'

## Restart/ Kill 
# Tear down and rebuild userspace login sessions
alias restart='sudo launchctl reboot userspace'
# https://applehelpwriter.com/2018/05/25/fastest-way-to-reboot-your-mac/
# TODO: Investigate "reboot apps"

# Kill the Dock, launchd will restart it automatically
alias killdock='killall Dock'

## Code Signing
# Check code signature of a file
alias cs='codesign --verify --deep --strict --verbose=4 '
# Check notarisation status of a file
alias gkchk='spctl --assess --type execute'
# Check code signature of a packged
alias pcs='pkgutil --check-signature '

## Python
# Activate python virtual environment
alias v!='. venv/bin/activate'
# Install Python packages from requirements.txt
alias r!='pip install -r requirements.txt'

## Plist
# Print bianry plist via PlistBuddy
# See also /usr/bin/plutil -p
alias ppl='/usr/libexec/PlistBuddy -c print '
# Lint given plst file for syntax errors
alias plint='plutil -lint '

## Gucci
# Pull pcap captures from Gucci into today's dated directory
alias gucci-fetch-pcaps='mkdir -p ~/Documents/Projects/ridleys-shooting-party/pcaps/$(date +%Y-%m-%d) && scp "gucci:/sdcard1/*.pcap" ~/Documents/Projects/ridleys-shooting-party/pcaps/$(date +%Y-%m-%d)/'

## Miscellaneous

# Create new local TM snapshots of all APFS volumes included in the TM backup
alias snap='tmutil localsnapshot'

# Completely unarchive a package
# Undocumented command
alias unpack='pkgutil --expand-full'

# Required to use the CLI since Tailscale is installed via App Store
# https://tailscale.com/kb/1080/cli
alias tailscale='/Applications/Tailscale.app/Contents/MacOS/Tailscale'

# Skip permission prompts (dcg hook + settings.json deny rules remain active)
alias claude='claude --dangerously-skip-permissions'

# Skip approval prompts and sandbox
alias codex='codex --dangerously-bypass-approvals-and-sandbox'

