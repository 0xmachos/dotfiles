#!/usr/bin/env zsh
# dotfiles/.functions/jump

function jump {
  # jump
  #   Update macOS, Homebrew, dcg, LaTeX packages & XProtect
  #   Run XProtect scan

  local -r SUDO_BINARY="/usr/bin/sudo"
  local -r SWUPDATE_BINARY="/usr/sbin/softwareupdate"
  local -r BREW_BINARY="/opt/homebrew/bin/brew"
  local -r TLMGR_BINARY="/Library/TeX/texbin/tlmgr"
  local -r XPROTECT_BINARY="/usr/bin/xprotect"
  local -r XPROTECT_APP="/Library/Apple/System/Library/CoreServices/XProtect.app/Contents/MacOS/XProtect"
  local -r DCG_BINARY="/usr/local/bin/dcg"


  ## macOS ##
  if ! [[ -x "${SWUPDATE_BINARY}" ]]; then
    echo "Cannot execute /usr/sbin/softwareupdate"
    return 1
  fi

  echo "[🍎] Updating macOS..."
  # Apple Silicon requires volume owner auth, not sudo
  # https://support.apple.com/guide/deployment/dep24dbdcf9e/web
  "${SWUPDATE_BINARY}" --install --all --include-config-data


  ## Homebrew ##
  if [[ -x "${BREW_BINARY}" ]]; then
    echo "[🍺] Updating Homebrew..."
    if "${BREW_BINARY}" update; then
      "${BREW_BINARY}" upgrade
      "${BREW_BINARY}" cleanup
      "${BREW_BINARY}" autoremove
      "${BREW_BINARY}" doctor
    else
      echo "[❌] Failed to update Homebrew"
    fi
  fi



  ## dcg ##
  if [[ -x "${DCG_BINARY}" ]]; then
    "${SUDO_BINARY}" --prompt="[⚠️ ] Password required to update dcg: " -v
    echo "[🛡️] Updating dcg..."
    "${SUDO_BINARY}" "${DCG_BINARY}" update --verify --system
    # dcg is ad-hoc signed; its CDHash changes per build. Refresh the
    # Santa FAA policy entry so reads of claude/settings.json keep working.
    local -r BITTERSWEET_BINARY="${HOME}/Documents/Projects/dotfiles/bittersweet"
    if [[ -x "${BITTERSWEET_BINARY}" ]]; then
      "${BITTERSWEET_BINARY}" dcg-sync
    fi
  fi


  ## LaTeX ##
  # GPG repo verification disabled: gnupg not installed, SHA-512 checksums
  # and HTTPS transport still protect package integrity. See TODOs.md.
  if [[ -x "${TLMGR_BINARY}" ]]; then
    "${SUDO_BINARY}" --prompt="[⚠️ ] Password required to run tlmgr: " -v
    echo "[📝] Updating LaTeX..."
    "${SUDO_BINARY}" "${TLMGR_BINARY}" --verify-repo=none update --self
    "${SUDO_BINARY}" "${TLMGR_BINARY}" --verify-repo=none update --all
  fi


  ## Local extras (gitignored, sourced if present) ##
  # Per-host updaters or one-offs that aren't part of the canonical update
  # set live in dotfiles/.extra/jump. The whole .extra/ directory is matched
  # by .gitignore's .extra* rule, so anything inside it stays local. The
  # sourced file runs inside this function's scope and may use ${SUDO_BINARY}.
  local -r EXTRA_JUMP="${HOME}/Documents/Projects/dotfiles/.extra/jump"
  if [[ -r "${EXTRA_JUMP}" ]]; then
    # shellcheck disable=SC1090
    source "${EXTRA_JUMP}"
  fi


  ## XProtect ##
  if [[ -x "${XPROTECT_BINARY}" ]]; then
    echo "[🛡️] Updating XProtect..."
    "${SUDO_BINARY}" --prompt="[⚠️ ] Password required to update XProtect: " -v
    "${SUDO_BINARY}" "${XPROTECT_BINARY}" update --prerelease
  fi

  if [[ -x "${XPROTECT_APP}" ]]; then
    echo "[🔍] Running XProtect scan in the background..."
    "${XPROTECT_APP}" &
  fi


  ## ImageIO OOP ##
  if [[ "$(launchctl getenv IIOEnableOOP)" != "1" ]]; then
    echo "[❌] IIOEnableOOP not set in launchd — GUI apps parsing images in-process"
    echo "    Run: launchctl setenv IIOEnableOOP 1"
    echo "    Or:  bittersweet launchagents"
  fi
}
