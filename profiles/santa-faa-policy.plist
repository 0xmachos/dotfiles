<!-- Santa File Access Authorization (FAA) Policy
     Protects high-value dotfiles from unauthorised reads and writes.
     Process-level identity enforcement — only allowlisted code-signed
     binaries can access watched files (chmod 600 only blocks other UIDs).

     Rules: SSH config, git signing config, shell startup, shell functions,
     Claude Code config. Each has symlink + resolved path pairs because
     ES resolves symlinks before evaluating AUTH_OPEN.

     Installed to /Library/Santa/faa-policy.plist by bittersweet santa-faa.
     Referenced by com.northpolesec.santa.vault.mobileconfig via FileAccessPolicyPlist.

     Allowlist is intentionally minimal — iterate as processes are blocked.
     ES resolves symlinks, so both symlink and resolved paths are watched. -->

<plist version="1.0">
<dict>

  <key>Version</key>
  <string>v1.0</string>

  <key>WatchItems</key>
  <dict>

    <!-- SSH config: symlink paths under ~/.ssh/ -->
    <key>SSHConfigSymlinks</key>
    <dict>
      <key>Paths</key>
      <array>
        <dict>
          <key>Path</key>
          <string>/Users/*/.ssh/config</string>
        </dict>
        <dict>
          <key>Path</key>
          <string>/Users/*/.ssh/.extra_ssh</string>
        </dict>
      </array>
      <key>Options</key>
      <dict>
        <key>AllowReadAccess</key>
        <false/>
        <key>AuditOnly</key>
        <false/>
        <key>RuleType</key>
        <string>PathsWithAllowedProcesses</string>
      </dict>
      <key>Processes</key>
      <array>
        <!-- ssh: reads config every invocation -->
        <dict>
          <key>SigningID</key>
          <string>com.apple.ssh</string>
          <key>PlatformBinary</key>
          <true/>
        </dict>
        <!-- scp: uses SSH transport -->
        <dict>
          <key>SigningID</key>
          <string>com.apple.scp</string>
          <key>PlatformBinary</key>
          <true/>
        </dict>
        <!-- sftp: uses SSH transport -->
        <dict>
          <key>SigningID</key>
          <string>com.apple.sftp</string>
          <key>PlatformBinary</key>
          <true/>
        </dict>
        <!-- Sublime Text: user's editor -->
        <dict>
          <key>SigningID</key>
          <string>com.sublimetext.4</string>
          <key>TeamID</key>
          <string>Z6D26JE4Y4</string>
        </dict>
        <!-- ln (com.apple.link): bittersweet recreates symlinks via ln -sfn -->
        <dict>
          <key>SigningID</key>
          <string>com.apple.link</string>
          <key>PlatformBinary</key>
          <true/>
        </dict>
      </array>
    </dict>

